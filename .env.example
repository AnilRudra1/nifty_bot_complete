# ─── Angel One SmartAPI ───────────────────────────────────────────────────────
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_PASSWORD=your_mpin_here
ANGEL_TOTP_SECRET=your_totp_base32_secret_here

# ─── Telegram Notifications ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Trading Mode: paper | live ───────────────────────────────────────────────
TRADING_MODE=paper

# ─── Risk Settings ────────────────────────────────────────────────────────────
CAPITAL=100000
RISK_PER_TRADE_PCT=1.5
MAX_LOSS_PER_DAY=99999
MAX_TRADES_PER_DAY=50
LOT_SIZE=50

# ─── Strategy Settings ────────────────────────────────────────────────────────
TIMEFRAME=FIVE_MINUTE
STRIKE_RANGE_POINTS=500
MIN_OI_THRESHOLD=100000
ATR_TRAIL_MULTIPLIER=1.5

# ─── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_PORT=5000
DASHBOARD_SECRET_KEY=change_this_to_a_random_string
